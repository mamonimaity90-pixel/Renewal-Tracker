{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "team"] }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Hospital": {
      "title": "Hospital",
      "description": "Healthcare facility details for compliance tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "state": { "type": "string" },
        "district": { "type": "string" },
        "pincode": { "type": "string" },
        "beds": { "type": "number" },
        "applicationNo": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "reapplied": { "type": "boolean" },
        "reappliedProgram": { "type": "string" },
        "renewalApplicationNo": { "type": "string" },
        "renewalApplicationDate": { "type": "string", "format": "date-time" },
        "assignedTo": { "type": "string" },
        "currentProgram": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Expired", "Pending Renewal"] },
        "contactPerson": { "type": "string" },
        "contactNumber": { "type": "string" }
      },
      "required": ["name", "status"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "Logged interaction with a hospital officer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hospitalId": { "type": "string" },
        "hospitalName": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "type": { "type": "string", "enum": ["call", "visit", "email", "other"] },
        "notes": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["hospitalId", "userId", "type", "timestamp"]
    },
    "Application": {
      "title": "Application",
      "description": "NABH application tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hospitalId": { "type": "string" },
        "hospitalName": { "type": "string" },
        "type": { "type": "string" },
        "applicationNo": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["hospitalId", "type", "applicationNo", "date"]
    },
    "ReportSchedule": {
      "title": "Report Schedule",
      "description": "Automated report configuration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly"] },
        "recipients": { "type": "string" },
        "type": { "type": "string", "enum": ["summary", "detailed"] },
        "createdBy": { "type": "string" },
        "lastSent": { "type": "string", "format": "date-time" }
      },
      "required": ["frequency", "recipients", "type"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Global application setting",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["key", "value"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "hospitals/{hospitalId}": {
      "schema": "Hospital",
      "description": "Hospital records"
    },
    "interactions/{interactionId}": {
      "schema": "Interaction",
      "description": "Communication logs"
    },
    "applications/{applicationId}": {
      "schema": "Application",
      "description": "NABH applications"
    },
    "report_schedules/{scheduleId}": {
      "schema": "ReportSchedule",
      "description": "Email report schedules"
    },
    "settings/{settingId}": {
      "schema": "Setting",
      "description": "System settings like API keys"
    }
  }
}
